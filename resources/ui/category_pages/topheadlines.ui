<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0" />
  <requires lib="libadwaita" version="1.0" />

  <template class="TopHeadlinesPage" parent="AdwNavigationPage">
    <child>
      <object class="AdwNavigationView" id="navigation_view">
        <child>
          <object class="AdwNavigationPage">
            <property name="can-pop">False</property>
            <property name="child">
              <object class="AdwToolbarView">
                <child type="top">

                  <object class="AdwHeaderBar">
                    <property name="show-title">false</property>
                    <child type="start">
                      <object class="GtkButton" id="open_sidebar_btn">
                        <property name="icon-name">sidebar-show-symbolic</property>
                        <style>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>

                  </object>
                </child>
                <child>
                  <object class="GtkStack" id="root_stack">
                    <property name="transition-type">crossfade</property>
                    <property name="hexpand">true</property>
                    <property name="vexpand">true</property>

                    <!-- LOADING STATE -->
                    <child>
                      <object class="GtkStackPage">
                        <property name="name">loading</property>
                        <property name="child">
                          <object class="GtkCenterBox">
                            <property name="hexpand">true</property>
                            <property name="vexpand">true</property>
                            <child type="center">
                              <object class="GtkSpinner">
                                <property name="spinning">true</property>
                                <property name="width-request">48</property>
                                <property name="height-request">48</property>
                              </object>
                            </child>
                          </object>
                        </property>
                      </object>
                    </child>

                    <!-- CONTENT STATE -->
                    <child>
                      <object class="GtkStackPage">
                        <property name="name">content</property>
                        <property name="child">
                          <object class="GtkScrolledWindow">
                            <property name="hexpand">true</property>
                            <property name="vexpand">true</property>
                            <property name="hscrollbar-policy">never</property>
                            <property name="vscrollbar-policy">automatic</property>

                            <child>
                              <object class="AdwClamp">
                                <property name="maximum-size">1400</property>
                                <property name="tightening-threshold">1000</property>
                                <property name="margin-top">24</property>
                                <property name="margin-bottom">24</property>

                                <child>
                                  <object class="GtkBox" id="main_content">
                                    <property name="orientation">vertical</property>
                                    <property name="spacing">32</property>
                                    <property name="margin-bottom">32</property>
                                    <property name="margin-start">24</property>
                                    <property name="margin-end">24</property>

                                    <!-- Header -->
                                    <child>
                                      <object class="GtkBox">
                                        <property name="orientation">vertical</property>
                                        <property name="spacing">8</property>

                                        <child>
                                          <object class="GtkLabel" id="title_label">
                                            <property name="label">FROST NEWS</property>
                                            <property name="halign">start</property>
                                            <style>
                                              <class name="accent"/>
                                              <class name="frost-brand-title"/>
                                            </style>
                                          </object>
                                        </child>

                                        <child>
                                          <object class="GtkLabel" id="current_date_label">
                                            <property name="halign">start</property>
                                            <style>
                                  <class name="frost-date-subtitle"/>
                                  <class name="dim-label"/>
                                </style>
                                          </object>
                                        </child>
                                      </object>
                                    </child>

                                    <!-- Featured Articles Section -->
                                    <child>
                                      <object class="GtkBox">
                                        <property name="orientation">vertical</property>
                                        <property name="spacing">16</property>

                                        <child>
                                          <object class="GtkScrolledWindow">
                                            <property name="hscrollbar-policy">automatic</property>
                                            <property name="vscrollbar-policy">never</property>
                                            <property name="min-content-height">300</property>

                                            <child>
                                              <object class="GtkBox" id="featured_box">
                                                <property name="orientation">vertical</property>
                                              </object>
                                            </child>
                                          </object>
                                        </child>
                                      </object>
                                    </child>

                                    <!-- Recent Articles Section -->
                                    <child>
                                      <object class="GtkBox">
                                        <property name="orientation">vertical</property>
                                        <property name="spacing">16</property>

                                        <child>
                                          <object class="GtkBox" id="articles_container">
                                            <property name="orientation">vertical</property>
                                            <property name="spacing">12</property>
                                          </object>
                                        </child>
                                      </object>
                                    </child>

                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </property>
                      </object>
                    </child>

                  </object>
                </child>
              </object>
            </property>
          </object>
        </child>


      </object>
    </child>
  </template>
</interface>